{
  "productName": "Herzies",
  "identifier": "app.herzies.desktop",
  "version": "0.1.0-beta.3",
  "build": {
    "beforeDevCommand": "pnpm vite:dev",
    "beforeBuildCommand": "pnpm vite:build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Herzies",
        "width": 380,
        "height": 520,
        "decorations": false,
        "resizable": false,
        "visible": false,
        "skipTaskbar": true,
        "transparent": false
      }
    ],
    "trayIcon": null
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "createUpdaterArtifacts": true,
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "icon": [
      "icons/iconTemplate.png",
      "icons/iconTemplate@2x.png"
    ],
    "category": "Music"
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDNDREI4QkY4NjQzMjRGNjgKUldSb1R6SmsrSXZiUEFnSWIvK1FlWHphWGZaTUwyNVVwUlFrSitaS3JkNjRFTW5oZGdaVVYvSFEK",
      "endpoints": [
        "https://github.com/Herzies/herzies/releases/latest/download/latest.json"
      ]
    }
  }
}
