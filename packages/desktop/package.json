{
  "name": "herzies-desktop",
  "version": "0.1.0-beta.1",
  "private": true,
  "description": "Herzies desktop app for macOS",
  "scripts": {
    "dev": "tauri dev",
    "check": "tsc --noEmit",
    "build": "tauri build",
    "build:signed": "bash scripts/build-signed.sh",
    "vite:dev": "vite dev --port 1420",
    "vite:build": "vite build",
    "sandbox": "vite dev --port 1420 --open /sandbox.html"
  },
  "dependencies": {
    "@herzies/shared": "workspace:*",
    "@supabase/supabase-js": "^2.105.1",
    "@tauri-apps/api": "^2.5.0",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.5.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.5.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "typescript": "^6.0.3",
    "vite": "^6.3.5"
  }
}
