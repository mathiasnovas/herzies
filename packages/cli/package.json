{
  "name": "herzies",
  "version": "0.4.0",
  "description": "A digital pet that lives in your terminal that grows by listening to music",
  "type": "module",
  "bin": {
    "herzies": "./dist/bin/herzies.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc",
    "dev": "tsc --watch",
    "preview": "node dist/src/commands/preview.js",
    "start": "node dist/bin/herzies.js"
  },
  "keywords": [
    "cli",
    "pet",
    "digital-pet",
    "music"
  ],
  "homepage": "https://www.herzies.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/Herzies/herzies.git",
    "directory": "packages/cli"
  },
  "license": "MIT",
  "dependencies": {
    "@herzies/shared": "workspace:*",
"chalk": "^5.6.2",
    "commander": "^14.0.3",
    "ink": "^7.0.1",
    "open": "^11.0.0",
    "react": "^19.2.5"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "typescript": "^6.0.3"
  }
}
