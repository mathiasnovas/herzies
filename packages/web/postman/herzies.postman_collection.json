    {
      "name": "Admin",
      "description": "Auth via `x-admin-secret: {{GAME_ADMIN_SECRET}}` header.",
      "auth": { "type": "noauth" },
      "item": [
        {
          "name": "GET /api/admin/events",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [{ "key": "x-admin-secret", "value": "{{GAME_ADMIN_SECRET}}" }],
            "url": { "raw": "{{BASE_URL}}/api/admin/events", "host": ["{{BASE_URL}}"], "path": ["api", "admin", "events"] }
          }
        },
        {
          "name": "POST /api/admin/events",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "x-admin-secret", "value": "{{GAME_ADMIN_SECRET}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"secret_track\",\n  \"title\": \"Discover Hidden Track\",\n  \"description\": \"Find the secret track\",\n  \"active\": true,\n  \"startsAt\": \"2026-05-01T00:00:00Z\",\n  \"endsAt\": \"2026-05-31T23:59:59Z\",\n  \"config\": {\n    \"rewardItemId\": \"item-123\",\n    \"rewardItemName\": \"Track Badge\",\n    \"rewardItemDescription\": \"Reward for discovering\",\n    \"rewardItemRarity\": \"legendary\",\n    \"maxClaims\": 100,\n    \"hints\": []\n  }\n}"
            },
            "url": { "raw": "{{BASE_URL}}/api/admin/events", "host": ["{{BASE_URL}}"], "path": ["api", "admin", "events"] }
          }
        },
        {
          "name": "POST /api/admin/grant-item",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "x-admin-secret", "value": "{{GAME_ADMIN_SECRET}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"itemId\": \"{{ITEM_ID}}\",\n  \"friendCode\": \"{{FRIEND_CODE}}\"\n}"
            },
            "url": { "raw": "{{BASE_URL}}/api/admin/grant-item", "host": ["{{BASE_URL}}"], "path": ["api", "admin", "grant-item"] }
          }
        },
        {
          "name": "GET /api/admin/multipliers",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [{ "key": "x-admin-secret", "value": "{{GAME_ADMIN_SECRET}}" }],
            "url": { "raw": "{{BASE_URL}}/api/admin/multipliers", "host": ["{{BASE_URL}}"], "path": ["api", "admin", "multipliers"] }
          }
        },
        {
          "name": "POST /api/admin/multipliers",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "x-admin-secret", "value": "{{GAME_ADMIN_SECRET}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Double XP\",\n  \"bonus\": 2.0,\n  \"active\": true,\n  \"startsAt\": \"2026-05-01T00:00:00Z\",\n  \"endsAt\": \"2026-05-31T23:59:59Z\",\n  \"schedule\": null\n}"
            },
            "url": { "raw": "{{BASE_URL}}/api/admin/multipliers", "host": ["{{BASE_URL}}"], "path": ["api", "admin", "multipliers"] }
          }
        },
        {
          "name": "DELETE /api/admin/multipliers",
          "request": {
            "auth": { "type": "noauth" },
