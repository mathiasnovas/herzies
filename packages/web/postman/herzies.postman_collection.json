    {
      "name": "Spotify (browser session)",
      "description": "These endpoints rely on the Supabase session cookie set in the browser, not a Bearer token. Best driven from the web app; included here for reference.",
      "item": [
        {
          "name": "GET /api/spotify/connect",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
