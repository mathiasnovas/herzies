    {
      "name": "Trade",
      "item": [
        {
          "name": "POST /api/trade/create",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "try {",
                  "  const json = pm.response.json();",
                  "  if (json && json.tradeId) {",
                  "    pm.collectionVariables.set('TRADE_ID', json.tradeId);",
                  "  }",
                  "} catch (_) {}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"targetFriendCode\": \"{{FRIEND_CODE_OTHER}}\"\n}"
            },
            "url": { "raw": "{{BASE_URL}}/api/trade/create", "host": ["{{BASE_URL}}"], "path": ["api", "trade", "create"] }
          }
        },
        {
          "name": "GET /api/trade/status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/api/trade/status?tradeId={{TRADE_ID}}",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "trade", "status"],
              "query": [{ "key": "tradeId", "value": "{{TRADE_ID}}" }]
            }
          }
        },
        {
          "name": "GET /api/trade/pending",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{BASE_URL}}/api/trade/pending", "host": ["{{BASE_URL}}"], "path": ["api", "trade", "pending"] }
          }
        },
