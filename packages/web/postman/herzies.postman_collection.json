            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/api/spotify/callback?code=&state=",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "spotify", "callback"],
              "query": [
                { "key": "code", "value": "" },
                { "key": "state", "value": "" },
                { "key": "error", "value": "", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "POST /api/spotify/disconnect",
          "request": {
