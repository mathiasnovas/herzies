{
  "info": {
    "name": "Herzies Web API",
    "description": "HTTP endpoints exposed by packages/web (Next.js App Router under /api). Most endpoints expect a Supabase access token in `Authorization: Bearer <token>`. Admin endpoints use `x-admin-secret`. The cron endpoint uses `Authorization: Bearer <CRON_SECRET>`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "herzies-web-api"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{SUPABASE_TOKEN}}", "type": "string" }
    ]
  },
  "variable": [
    { "key": "BASE_URL", "value": "http://localhost:3000", "type": "string" },
    { "key": "SUPABASE_TOKEN", "value": "", "type": "string", "description": "Supabase access token (Bearer)." },
    { "key": "GAME_ADMIN_SECRET", "value": "", "type": "string", "description": "Value of GAME_ADMIN_SECRET, sent as x-admin-secret." },
    { "key": "CRON_SECRET", "value": "", "type": "string", "description": "Value of CRON_SECRET, sent as Bearer on /api/cron/*." },
    { "key": "FRIEND_CODE", "value": "HERZ-1111", "type": "string" },
    { "key": "FRIEND_CODE_OTHER", "value": "HERZ-2222", "type": "string" },
    { "key": "TRADE_ID", "value": "", "type": "string" },
    { "key": "ITEM_ID", "value": "", "type": "string" },
    { "key": "EVENT_ID", "value": "", "type": "string" },
    { "key": "REFRESH_TOKEN", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Public",
      "item": [
        {
          "name": "GET /api/health",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": { "raw": "{{BASE_URL}}/api/health", "host": ["{{BASE_URL}}"], "path": ["api", "health"] }
          }
        },
        {
          "name": "GET /api/lookup (single)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/api/lookup?code={{FRIEND_CODE}}",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "lookup"],
              "query": [{ "key": "code", "value": "{{FRIEND_CODE}}" }]
            }
          }
        },
        {
          "name": "GET /api/lookup (batch)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/api/lookup?codes={{FRIEND_CODE}},{{FRIEND_CODE_OTHER}}",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "lookup"],
              "query": [{ "key": "codes", "value": "{{FRIEND_CODE}},{{FRIEND_CODE_OTHER}}", "description": "Comma-separated, max 50." }]
            }
          }
        },
        {
          "name": "GET /api/name-check",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/api/name-check?name=Sparky",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "name-check"],
              "query": [{ "key": "name", "value": "Sparky" }]
            }
          }
        },
        {
          "name": "GET /api/events/active",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": { "raw": "{{BASE_URL}}/api/events/active", "host": ["{{BASE_URL}}"], "path": ["api", "events", "active"] }
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /api/auth/refresh",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{REFRESH_TOKEN}}\"\n}"
            },
            "url": { "raw": "{{BASE_URL}}/api/auth/refresh", "host": ["{{BASE_URL}}"], "path": ["api", "auth", "refresh"] }
          }
        }
      ]
    },
